{
  "info": {
    "name": "Inventory API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Login Admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"Admin123!\"\n}"
        }
      }
    },
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"registro@demo.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Usuario Registro\"\n}"
        }
      }
    },
    {
      "name": "Auth - Login User",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@demo.com\",\n  \"password\": \"User123!\"\n}"
        }
      }
    },
    {
      "name": "Products - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products?offset=0&limit=10&search=&from=&to="
      }
    },
    {
      "name": "Products - Detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products/{{productId}}"
      }
    },
    {
      "name": "Products - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/products",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Teclado Mecánico\",\n  \"description\": \"Teclado RGB hot swap\",\n  \"price\": 120.5,\n  \"category\": \"Periféricos\",\n  \"images\": [\"https://images.unsplash.com/photo-1517336714739-489689fd1ca8\"],\n  \"stock\": 25\n}"
        }
      }
    },
    {
      "name": "Products - Update",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/products/{{productId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 129.99,\n  \"stock\": 20\n}"
        }
      }
    },
    {
      "name": "Products - Delete (Soft)",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/products/{{productId}}"
      }
    },
    {
      "name": "Users - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users?offset=0&limit=10&active=true"
      }
    },
    {
      "name": "Users - Detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/users/{{userId}}"
      }
    },
    {
      "name": "Users - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/users",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"nuevo@demo.com\",\n  \"password\": \"Password123!\",\n  \"name\": \"Nuevo Usuario\",\n  \"role\": \"USER\",\n  \"active\": true\n}"
        }
      }
    },
    {
      "name": "Users - Update",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/users/{{userId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Usuario Editado\",\n  \"role\": \"ADMIN\"\n}"
        }
      }
    },
    {
      "name": "Users - Toggle Active",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/users/{{userId}}/status",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"active\": false\n}"
        }
      }
    }
  ]
}
